# 局域网安全监控系统 - 敏感信息配置
# 
# ⚠️ 安全提示：
# 1. 复制此文件为 .env
# 2. 填写你的敏感信息
# 3. 确保 .env 文件已添加到 .gitignore
# 4. 不要提交 .env 文件到版本控制系统

# ==================== 配置文件加密 ====================
# 配置文件加密密码（可选，如果要使用加密配置文件）
# CONFIG_ENCRYPT_PASSWORD=your_encryption_password_here

# ==================== Bark通知配置 ====================
# Bark密钥（必需）
# 获取方法：在iPhone上打开Bark应用，点击右上角"复制"按钮
BARK_KEY=your_bark_key_here

# ==================== 爱快路由器配置 ====================
# 爱快路由器密码（如果需要自动隔离）
IKUAI_PASSWORD=your_router_password_here

# ==================== 数据库配置（可选）====================
# MySQL数据库密码（如果使用MySQL）
# DB_PASSWORD=your_db_password_here