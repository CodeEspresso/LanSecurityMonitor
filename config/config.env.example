#!/bin/bash
# 局域网安全监控系统配置文件

# ==================== 网络配置 ====================
# 监控的网段（CIDR格式）
NETWORK_RANGE=192.168.1.0/24

# 网关IP地址
GATEWAY_IP=192.168.1.1

# DNS服务器
DNS_SERVERS=8.8.8.8,114.114.114.114

# ==================== 监控配置 ====================
# 检查间隔（秒）
CHECK_INTERVAL=300

# 日志级别（DEBUG/INFO/WARNING/ERROR/CRITICAL）
LOG_LEVEL=INFO

# 是否启用调试模式
DEBUG_MODE=false

# ==================== 威胁检测配置 ====================
# 是否启用威胁检测
ENABLE_THREAT_DETECTION=true

# 告警阈值（low/medium/high/critical）
ALERT_THRESHOLD=medium

# 是否自动隔离高风险设备
ENABLE_AUTO_ISOLATE=false

# 可疑端口列表（逗号分隔）
SUSPICIOUS_PORTS=4444,5555,6666,7777,8888,31337,12345,27374,3133,6667

# 是否启用端口扫描
ENABLE_PORT_SCAN=false

# 端口扫描范围（如 1-1000 或 22,80,443,3389）
PORT_SCAN_RANGE=22,80,443,445,3389,5000,8000,8080,8443

# 端口扫描超时时间（秒）
PORT_SCAN_TIMEOUT=60

# 已知设备白名单（MAC地址，逗号分隔）
# WHITELIST_MACS=aa:bb:cc:dd:ee:ff,11:22:33:44:55:66

# ==================== Bark通知配置 ====================
# Bark服务器地址
BARK_SERVER=https://api.day.app

# Bark密钥（必需）
# ⚠️ 安全提示：不要在配置文件中明文存储密钥！
# 请使用以下方式之一：
# 1. 设置环境变量：export BARK_KEY=your_key_here
# 2. 在Docker Compose中设置：environment: - BARK_KEY=your_key_here
# 3. 创建 .env 文件并添加到 .gitignore
BARK_KEY=

# 是否启用Bark通知
ENABLE_BARK=true

# 通知级别（仅发送指定级别以上的通知）
# 可选值: low, medium, high, critical
BARK_ALERT_LEVEL=medium

# 是否发送新设备通知
NOTIFY_NEW_DEVICE=true

# 是否发送威胁通知
NOTIFY_THREAT=true

# 是否发送设备离线通知
NOTIFY_DEVICE_OFFLINE=false

# ==================== 通知策略配置 ====================
# 智能家居设备上下线是否通知
NOTIFY_SMART_HOME_CHANGES=false

# 设备首次出现是否直接告警（false=加入待确认列表）
NOTIFY_FIRST_SEEN_IMMEDIATELY=false

# 静默时段（逗号分隔，格式：开始小时-结束小时）
# SILENT_PERIODS=0-7,12-14

# 通知分组（按设备分类）
NOTIFY_BY_CATEGORY=true

# 重复通知间隔（分钟，防止告警风暴）
NOTIFICATION_COOLDOWN=15

# ==================== 数据库配置 ====================
# 数据库类型（sqlite/mysql）
DB_TYPE=sqlite

# SQLite数据库文件路径
DB_FILE=data/security.db

# MySQL配置（如果使用MySQL）
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=password
# DB_NAME=lan_security

# ==================== 高级配置 ====================
# 网络扫描超时（秒）
SCAN_TIMEOUT=30

# 最大并发扫描数
MAX_CONCURRENT_SCANS=10

# 设备离线判定时间（秒）
DEVICE_OFFLINE_THRESHOLD=600

# 历史记录保留天数
HISTORY_RETENTION_DAYS=30

# ==================== NAS监控配置 ====================
# 是否启用NAS监控
ENABLE_NAS_MONITOR=true

# NAS设备MAC地址列表（逗号分隔）
# NAS_DEVICES=00:11:32:AA:BB:CC,00:50:56:DD:EE:FF

# 信任的外部IP列表（逗号分隔，例如你的公网IP）
# TRUSTED_EXTERNAL_IPS=1.2.3.4,5.6.7.8

# 带宽异常阈值（KB/s）
BANDWIDTH_THRESHOLD=1024

# 连接检查超时（秒）
CONNECTION_TIMEOUT=10

# ==================== 设备行为分析配置 ====================
# 是否启用设备行为分析
ENABLE_BEHAVIOR_ANALYSIS=true

# 最小观察次数（达到此次数才开始分析）
MIN_OBSERVATIONS=7

# 异常阈值
ANOMALY_THRESHOLD=3

# 学习周期（天）
LEARNING_PERIOD_DAYS=30

# 活跃时间识别阈值（0.0-1.0），越高表示活跃时间范围越集中
ACTIVE_HOUR_THRESHOLD=0.6

# 活跃时间容差（小时），当前时间在活跃时间±此范围内不算异常
ACTIVE_HOUR_TOLERANCE=1

# ==================== 设备风险评估配置 ====================
# 是否启用设备风险评估（ML分析）
ENABLE_RISK_ANALYSIS=true

# 设备风险阈值（0-100，超过此分数则发送警报）
DEVICE_RISK_THRESHOLD=60

# 高风险阈值（0-100，超过此分数为高风险设备）
HIGH_RISK_THRESHOLD=80

# ==================== 机器学习配置 ====================
# 是否启用ML风险增强（使用scikit-learn随机森林）
ENABLE_ML_RISK=true

# 是否启用ML行为异常检测（使用Isolation Forest）
ENABLE_ML_BEHAVIOR=true

# ML模型存储目录
ML_MODEL_DIR=data/ml_models

# ML最小训练样本数（低于此数量使用规则基础模型）
ML_MIN_TRAINING_SAMPLES=30

# ML行为检测最小样本数
ML_BEHAVIOR_MIN_SAMPLES=30

# ML异常检测污染率（Isolation Forest参数）
ML_ANOMALY_CONTAMINATION=0.1

# ML异常检测阈值
ML_ANOMALY_THRESHOLD=0.5

# ==================== Grafana联动配置 ====================
# 是否启用指标导出
ENABLE_METRICS=true

# 指标服务器端口
METRICS_PORT=9100

# 指标服务器监听地址
METRICS_HOST=0.0.0.0

# ==================== 带宽监控配置 ====================
# 是否启用带宽监控
ENABLE_BANDWIDTH_MONITOR=true

# 上传带宽阈值（KB/s）
UPLOAD_THRESHOLD=512

# 下载带宽阈值（KB/s）
DOWNLOAD_THRESHOLD=2048

# 带宽监控间隔（秒）
BANDWIDTH_MONITOR_INTERVAL=60

# ==================== 设备隔离配置 ====================
# 隔离方式（ikuai_router/manual）
# ikuai_router: 使用爱快路由器API自动添加黑名单
# manual: 手动处理，只发送通知
ISOLATION_METHOD=ikuai_router

# ==================== 爱快路由器配置 ====================
# 爱快路由器地址
IKUAI_URL=http://192.168.1.1

# 爱快路由器端口（默认80）
IKUAI_PORT=80

# 爱快路由器用户名
IKUAI_USERNAME=admin

# 爱快路由器密码
# ⚠️ 安全提示：不要在配置文件中明文存储密码！
# 请使用以下方式之一：
# 1. 设置环境变量：export IKUAI_PASSWORD=your_password
# 2. 在Docker Compose中设置：environment: - IKUAI_PASSWORD=your_password
# 3. 创建 .env 文件并添加到 .gitignore
IKUAI_PASSWORD=

# ==================== 自动封禁配置 ====================
# 是否启用自动封禁（检测到高风险设备时自动添加到黑名单）
AUTO_BLOCK_ENABLED=false

# 自动封禁风险阈值（0-100，达到此值时自动封禁）
AUTO_BLOCK_THRESHOLD=80

# ==================== Web管理界面配置 ====================
# 是否启用Web界面
ENABLE_WEB=true

# Web服务器端口
WEB_PORT=5000

# Web服务器监听地址
WEB_HOST=0.0.0.0

# Web界面用户名
WEB_USERNAME=admin

# Web界面密码
# ⚠️ 安全提示：不要在配置文件中明文存储密码！
# 请使用以下方式之一：
# 1. 设置环境变量：export WEB_PASSWORD=your_password
# 2. 在Docker Compose中设置：environment: - WEB_PASSWORD=your_password
# 3. 创建 .env 文件并添加到 .gitignore
WEB_PASSWORD=admin123

# Web界面密钥（用于session加密）
# ⚠️ 安全提示：请修改为随机字符串！
WEB_SECRET_KEY=lan-security-monitor-secret-key-2024

# 是否启用调试模式（生产环境请设置为false）
WEB_DEBUG=false
